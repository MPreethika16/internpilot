```gitignore
# ==========================
# Dependencies
# ==========================
node_modules/

# ==========================
# Build Output
# ==========================
dist/
build/

# ==========================
# Logs
# ==========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================
# Environment Variables
# ==========================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ==========================
# Prisma
# ==========================
prisma/dev.db
prisma/dev.db-journal

# ==========================
# Coverage
# ==========================
coverage/
.nyc_output/

# ==========================
# TypeScript
# ==========================
*.tsbuildinfo

# ==========================
# IDEs
# ==========================
.vscode/
.idea/

# ==========================
# OS Files
# ==========================
.DS_Store
Thumbs.db

# ==========================
# Temporary Files
# ==========================
tmp/
temp/
.cache/

# ==========================
# Docker
# ==========================
docker-compose.override.yml

# ==========================
# Misc
# ==========================
*.pid
*.seed
*.pid.lock
```
