generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum AuthProvider {
  EMAIL
  GOOGLE
  GITHUB
}

enum UserRole {
  STUDENT
  RECRUITER
  ADMIN
}

enum SkillSource {
  RESUME
  MANUAL
  AI
}

enum InternshipStatus {
  ACTIVE
  EXPIRED
  REMOVED
}

enum InternshipMode {
  REMOTE
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

//////////////////////
// USER
//////////////////////

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  passwordHash   String?
  authProvider   AuthProvider
  role           UserRole

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  studentProfile StudentProfile?
  resumes        Resume[]
  userSkills     UserSkill[]
  applications   Application[]
}

//////////////////////
// STUDENT PROFILE
//////////////////////

model StudentProfile {
  id                String   @id @default(uuid())
  userId            String   @unique

  fullName          String
  phone             String?
  university        String
  degree            String

  graduationYear    Int
  cgpa              Float?

  currentLocation   String?
  preferredLocation String?

  linkedinUrl       String?
  githubUrl         String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////
// RESUME
//////////////////////

model Resume {
  id             String   @id @default(uuid())

  userId         String

  fileName       String
  fileUrl        String

  extractedText  String?

  parsingStatus  String @default("PENDING")

  uploadedAt     DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

//////////////////////
// SKILL
//////////////////////

model Skill {
  id          String @id @default(uuid())

  name        String @unique
  category    String?

  userSkills        UserSkill[]
  internshipSkills  InternshipSkill[]
}

//////////////////////
// USER SKILL
//////////////////////

model UserSkill {

  id               String @id @default(uuid())

  userId           String
  skillId          String

  confidenceScore  Float?

  source           SkillSource

  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id],onDelete: Cascade)

  skill Skill @relation(fields: [skillId],references: [id])

  @@unique([userId, skillId])
}

//////////////////////
// COMPANY
//////////////////////

model Company {

  id             String @id @default(uuid())

  name           String @unique

  website        String?

  industry       String?

  headquarters   String?

  logoUrl        String?

  about          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  internships Internship[]
}

//////////////////////
// INTERNSHIP
//////////////////////

model Internship {

  id                   String @id @default(uuid())

  companyId            String

  title                String

  description          String

  eligibility          String?

  stipend              String?

  benefits             String?

  mode                 InternshipMode?

  location             String?

  applicationUrl       String

  applicationDeadline  DateTime?

  sourcePlatform       String

  sourceUrl            String?

  externalId           String

  status               InternshipStatus @default(ACTIVE)

  lastScrapedAt        DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  internshipSkills InternshipSkill[]

  applications Application[]

  @@unique([sourcePlatform, externalId])
}

//////////////////////
// INTERNSHIP SKILL
//////////////////////

model InternshipSkill {

  id             String @id @default(uuid())

  internshipId   String

  skillId        String

  internship Internship @relation(fields: [internshipId], references: [id])

  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([internshipId, skillId])
}

//////////////////////
// APPLICATION
//////////////////////

model Application {

  id              String @id @default(uuid())

  userId          String

  internshipId    String

  status          ApplicationStatus @default(APPLIED)

  appliedAt       DateTime @default(now())

  notes           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

 internship Internship @relation(fields: [internshipId], references: [id])

  @@unique([userId, internshipId])
}